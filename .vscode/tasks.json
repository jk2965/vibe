{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Spring Boot 실행",
      "type": "shell",
      "command": "mvn spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "Backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting",
          "endsPattern": "Started"
        }
      }
    },
    {
      "label": "Frontend: Vue Dev Server 실행",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "Frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "전체 실행 (Backend + Frontend)",
      "dependsOn": [
        "Backend: Spring Boot 실행",
        "Frontend: Vue Dev Server 실행"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
